generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  category    String
  shortDesc   String
  description String   @db.Text
  coverImage  String   @default("")
  images      String[]
  specs       Json
  tags        String[]
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  quoteRequests QuoteRequest[]
}

model Project {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  category      String
  client        String
  location      String
  province      String
  year          Int
  contractValue BigInt?
  shortDesc     String
  description   String   @db.Text
  coverImage    String   @default("")
  images        String[]
  featured      Boolean  @default(false)
  published     Boolean  @default(true)
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  title       String
  category    String
  description String   @db.Text
  icon        String
  image       String?
  published   Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  phone       String
  email       String?
  company     String?
  productName String
  message     String?  @db.Text
  status      String   @default("NEW") // NEW | PROCESSING | QUOTED | CLOSED
  note        String?  @db.Text
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  phone     String
  email     String?
  subject   String?
  message   String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
